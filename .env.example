# Server Monitor — environment configuration
# Copy this file to .env and adjust values as needed.

MONITOR_API_TOKEN=changeme
MONITOR_ALLOW_RESTART=0
MONITOR_RESTART_COMMAND=sudo /sbin/reboot
MONITOR_POLL_INTERVAL=2
MONITOR_HOSTNAME_LABEL=server
MONITOR_METRICS_REFRESH=1.5
MONITOR_HEAVY_REFRESH=5
MONITOR_TOP_PROCESSES=6
MONITOR_PROCESS_SCAN_LIMIT=200
